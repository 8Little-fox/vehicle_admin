{
  "name": "vehicle-admin",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "bin": "server.cjs",
  "scripts": {
    "dev": "rsbuild dev",
    "postinstall": "esno scripts/svg2json.ts",
    "build": "rsbuild build",
    "build:win": "rsbuild build && pkg .",
    "preview": "rsbuild preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@iconify/tools": "^4.1.2",
    "@tailwindcss/postcss": "^4.0.15",
    "@tanstack/vue-query": "^5.69.0",
    "@vueuse/core": "^13.0.0",
    "dayjs": "^1.11.13",
    "echarts": "^5.6.0",
    "esno": "^4.8.0",
    "express": "^4.21.2",
    "lodash-es": "^4.17.21",
    "naive-ui": "^2.41.0",
    "ohash": "^2.0.11",
    "pkg": "^5.8.1",
    "rspack-plugin-virtual-module": "^0.1.13",
    "tailwindcss": "^4.0.15",
    "taze": "^19.0.2",
    "unplugin-auto-import": "^19.1.1",
    "unplugin-vue-components": "^28.4.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.10.2",
    "@iconify/json": "^2.2.319",
    "@iconify/tailwind": "^1.2.0",
    "@playwright/test": "^1.52.0",
    "@rsbuild/core": "^1.2.19",
    "@rsbuild/plugin-vue": "^1.0.7",
    "@tanstack/vue-query-devtools": "^5.69.0",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^9.22.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "typescript": "^5.8.2",
    "unplugin-vue-router": "^0.12.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "vue-demi"
    ],
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild"
    ]
  },
  "pkg": {
    "assets": ["dist/**/*"],
    "targets": ["node18-win-x64"],
    "outputPath": "output"
  }
}
